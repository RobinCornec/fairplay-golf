{
  "expo": {
    "name": "FairPlay Golf",
    "slug": "fairplay-golf",
    "version": "1.0.0",
    "scheme": "fairplay",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F3D2E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.robincornec.gwolf",
      "versionCode": 4,
      "permissions": [],
      "edgeToEdgeEnabled": true,
    },
    "plugins": [
      "expo-localization",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "f00cad9b-9812-4e7e-b485-a079db0931d5"
      }
    },
    "owner": "robincornec"
  }
}